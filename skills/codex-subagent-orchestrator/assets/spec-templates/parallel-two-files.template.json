{
  "cwd": ".",
  "cwd_resolution": "invocation",
  "output_dir": "subagent-runs/parallel-two-files",
  "manifest_file": "subagent-runs/parallel-two-files/orchestration-manifest.json",
  "skip_git_repo_check": true,
  "execution_mode": "parallel",
  "write_prompt_files": true,
  "write_summary_file": true,
  "shared_directive_mode": "reference",
  "defaults": {
    "model": "gpt-5.4",
    "sandbox": "workspace-write",
    "reasoning_effort": "low",
    "prompt_profile": "compact",
    "response_style": "compact",
    "max_response_lines": 3
  },
  "agents": [
    {
      "name": "alpha-writer",
      "kind": "implementer",
      "stage": 1,
      "role": "parallel worker alpha",
      "mission": "Create the first independent file without touching beta output.",
      "task": "Create or replace alpha.txt in the working directory containing exactly the text ALPHA.",
      "read_first": [
        "AGENTS.md"
      ],
      "required_paths": [
        "alpha.txt"
      ],
      "required_non_empty_paths": [
        "alpha.txt"
      ],
      "writable_scope": [
        "alpha.txt"
      ],
      "validation": [
        "Ensure alpha.txt exists.",
        "Ensure alpha.txt contains exactly ALPHA."
      ],
      "return_contract": [
        "Confirm alpha.txt was created and verified."
      ]
    },
    {
      "name": "beta-writer",
      "kind": "implementer",
      "stage": 1,
      "role": "parallel worker beta",
      "mission": "Create the second independent file without touching alpha output.",
      "task": "Create or replace beta.txt in the working directory containing exactly the text BETA.",
      "read_first": [
        "AGENTS.md"
      ],
      "required_paths": [
        "beta.txt"
      ],
      "required_non_empty_paths": [
        "beta.txt"
      ],
      "writable_scope": [
        "beta.txt"
      ],
      "validation": [
        "Ensure beta.txt exists.",
        "Ensure beta.txt contains exactly BETA."
      ],
      "return_contract": [
        "Confirm beta.txt was created and verified."
      ]
    }
  ]
}
